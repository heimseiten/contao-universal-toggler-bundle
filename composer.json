{
    "name": "heimseiten/contao-universal-toggler-bundle",
    "description": "Elemente schalten durch einen Klick oder durch das Erscheinen im Viewport. Ein beliebiges Element kann als Schalter für andere beliebige Elemente eingestellt werden, um beispielsweise Elemente ein- und auszublenden. Beispiel siehe https://github.com/heimseiten/contao-universal-toggler-bundle",
    "keywords": [
        "toggler",
        "javscript",
        "accordion",
        "button"
    ],
    "type": "contao-bundle",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "heimseiten.de - Webdesign aus Köln",
            "email": "info@heimseiten.de",
            "homepage": "https://www.heimseiten.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/heimseiten/contao-universal-toggler-bundle/issues",
        "source": "https://github.com/heimseiten/contao-universal-toggler-bundle"
    },
    "require": {
        "contao/core-bundle": "^4.4 | ^5.0"
    },
    "require-dev": {
        "contao/easy-coding-standard": "^3.0",
        "contao/manager-plugin": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Heimseiten\\ContaoUniversalTogglerBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Heimseiten\\ContaoUniversalTogglerBundle\\ContaoManager\\Plugin"
    }
}
